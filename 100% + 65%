--// Perfect Hit + 65% Power + Auto-Mine | Module for LO Hub
--// PlaceId: 12196278347
--// ZERO external dependencies - hub provides everything

local Module = {}

--// State (hub will inject these via Setup)
Module.enabled = false
Module.perfectEnabled = true
Module.powerLimitEnabled = true
Module.autoMineEnabled = false
Module.mineRadius = 10
Module.mineInterval = 0.4
Module.mineTimeout = 15
Module.blastshardLimit = 0.65
Module.connections = {}
Module.activeOres = {}
Module.isMining = false
Module.currentTarget = nil
Module.logs = {}

--// Hub-injected references (set by Setup)
Module.Hub = nil        -- Hub window/table
Module.Services = nil   -- {Players, RS, RunService, etc}
Module.Remotes = nil    -- {Charge, Attack, DelayBar}
Module.Player = nil     -- LocalPlayer
Module.Character = nil  -- Current character
Module.HRP = nil        -- HumanoidRootPart
Module.Humanoid = nil   -- Humanoid

--// Utility
local function trackConnection(conn)
    if conn then table.insert(Module.connections, conn) end
    return conn
end

local function clearConnections()
    for _, conn in ipairs(Module.connections) do
        pcall(function() conn:Disconnect() end)
    end
    Module.connections = {}
end

local function addLog(text, color)
    color = color or Color3.fromRGB(220, 220, 230)
    table.insert(Module.logs, {text = text, color = color, time = os.clock()})
    if #Module.logs > 50 then table.remove(Module.logs, 1) end
    if Module.onLog then Module.onLog(text, color) end
end

--// Setup - called by hub with all dependencies
function Module.Setup(hub, services, remotes, player, char, hrp, humanoid)
    Module.Hub = hub
    Module.Services = services
    Module.Remotes = remotes
    Module.Player = player
    Module.Character = char
    Module.HRP = hrp
    Module.Humanoid = humanoid

    addLog("Module setup complete", Color3.fromRGB(0, 255, 200))
    return Module
end

--// Get Equipped Pickaxe
local function getEquippedPickaxe()
    if not Module.Character then return nil end
    for _, child in ipairs(Module.Character:GetChildren()) do
        if child:IsA("Tool") and (child.Name:find("Pickaxe") or child:GetAttribute("ToolType") == "Pickaxe") then
            return child
        end
    end
    return nil
end

--// Equip Pickaxe from Backpack
local function equipPickaxe()
    if not Module.Character then return false end
    local backpack = Module.Player:FindFirstChild("Backpack")
    if not backpack then return false end
    local humanoid = Module.Character:FindFirstChild("Humanoid")
    if not humanoid then return false end

    if getEquippedPickaxe() then return true end

    for _, child in ipairs(backpack:GetChildren()) do
        if child:IsA("Tool") and (child.Name:find("Pickaxe") or child:GetAttribute("ToolType") == "Pickaxe") then
            humanoid:EquipTool(child)
            task.wait(0.3)
            return getEquippedPickaxe() ~= nil
        end
    end
    return false
end

--// Find Hittable Part in Ore Model
local function getHittablePart(oreModel)
    if not oreModel then return nil end

    local hittable = oreModel:FindFirstChild("Hittable")
    if hittable then
        for _, child in ipairs(hittable:GetChildren()) do
            if child:IsA("BasePart") then return child end
        end
    end

    local hitbox = oreModel:FindFirstChild("Hitbox")
    if hitbox and hitbox:IsA("BasePart") then return hitbox end

    for _, child in ipairs(oreModel:GetDescendants()) do
        if child:IsA("BasePart") then return child end
    end

    return nil
end

--// Get Ore Position
local function getOrePosition(oreModel)
    local hittable = getHittablePart(oreModel)
    if hittable then return hittable.Position end
    if oreModel.PrimaryPart then return oreModel.PrimaryPart.Position end
    for _, child in ipairs(oreModel:GetDescendants()) do
        if child:IsA("BasePart") then return child.Position end
    end
    return nil
end

--// Send Perfect Hit - 65% FOR ALL ORES
local function sendPerfectHit(targetOre)
    if not Module.Remotes or not Module.Remotes.Attack then
        addLog("Attack remote not found!", Color3.fromRGB(255, 50, 50))
        return
    end

    -- ALWAYS 65% for everything
    local alpha = Module.blastshardLimit
    local responseTime = 0.76456

    pcall(function()
        Module.Remotes.Attack:FireServer({
            Alpha = alpha,
            ResponseTime = responseTime,
            AnimSpeed = 1,
            DamageMultiplier = 1,
            Target = targetOre,
            HitPosition = targetOre and targetOre.CFrame or CFrame.new()
        })
    end)
end

--// Send Charge
local function sendCharge(targetOre)
    if not Module.Remotes or not Module.Remotes.Charge then
        addLog("Charge remote not found!", Color3.fromRGB(255, 50, 50))
        return
    end

    pcall(function()
        Module.Remotes.Charge:FireServer({
            HitPosition = targetOre and targetOre.CFrame or CFrame.new(),
            Target = targetOre,
            Alpha = Module.blastshardLimit -- 65% for all
        })
    end)
end

--// MOUSE SIMULATION: Click on ore
local function simulateClickOnOre(orePart)
    if not orePart or not orePart.Parent then return false end
    if not Module.Services or not Module.Services.VirtualInputManager then return false end

    local vim = Module.Services.VirtualInputManager
    local camera = workspace.CurrentCamera
    if not camera then return false end

    local worldPos = orePart.Position
    local screenPos, onScreen = camera:WorldToViewportPoint(worldPos)
    if not onScreen then return false end

    local mousePos = Vector2.new(screenPos.X, screenPos.Y)

    pcall(function()
        vim:SendMouseMoveEvent(mousePos.X, mousePos.Y, game)
    end)
    task.wait(0.05)

    pcall(function()
        vim:SendMouseButtonEvent(mousePos.X, mousePos.Y, 0, true, game, 0)
    end)
    task.wait(0.05)

    pcall(function()
        vim:SendMouseButtonEvent(mousePos.X, mousePos.Y, 0, false, game, 0)
    end)
    task.wait(0.05)

    return true
end

--// Find Ores in Radius
local function findOresInRadius(radius)
    radius = radius or Module.mineRadius
    if not Module.HRP then return {} end

    local found = {}
    local playerPos = Module.HRP.Position

    local worldSpawn = workspace:FindFirstChild("WorldSpawn")
    if not worldSpawn then return {} end

    local oresFolder = worldSpawn:FindFirstChild("Ores")
    if oresFolder then
        for _, ore in ipairs(oresFolder:GetChildren()) do
            if ore.Name ~= "_Decoration" then
                local pos = getOrePosition(ore)
                if pos then
                    local dist = (playerPos - pos).Magnitude
                    if dist <= radius then
                        table.insert(found, {
                            model = ore,
                            part = getHittablePart(ore),
                            position = pos,
                            distance = dist,
                            name = ore.Name
                        })
                    end
                end
            end
        end
    end

    local treesFolder = worldSpawn:FindFirstChild("Trees")
    if treesFolder then
        for _, tree in ipairs(treesFolder:GetChildren()) do
            if tree.Name ~= "_Decoration" then
                local pos = getOrePosition(tree)
                if pos then
                    local dist = (playerPos - pos).Magnitude
                    if dist <= radius then
                        table.insert(found, {
                            model = tree,
                            part = getHittablePart(tree),
                            position = pos,
                            distance = dist,
                            name = tree.Name,
                            isTree = true
                        })
                    end
                end
            end
        end
    end

    table.sort(found, function(a, b) return a.distance < b.distance end)
    return found
end

--// Mine Single Ore
local function mineOre(oreData)
    if Module.isMining then return false end
    Module.isMining = true
    Module.currentTarget = oreData

    if not Module.Character or not Module.HRP then
        Module.isMining = false
        return false
    end

    local oreModel = oreData.model
    local hittablePart = oreData.part
    if not hittablePart or not hittablePart.Parent then
        Module.isMining = false
        return false
    end

    if not equipPickaxe() then
        addLog("No pickaxe found!", Color3.fromRGB(255, 50, 50))
        Module.isMining = false
        return false
    end
    task.wait(0.3)

    local orePos = hittablePart.Position
    local targetPos = orePos

    local direction = (Module.HRP.Position - orePos)
    if direction.Magnitude < 0.1 then direction = Vector3.new(1, 0, 0) end
    direction = direction.Unit
    local standDistance = math.max(hittablePart.Size.X, hittablePart.Size.Z, 3) + 3
    targetPos = orePos + direction * standDistance
    targetPos = Vector3.new(targetPos.X, orePos.Y + 2, targetPos.Z)

    Module.HRP.CFrame = CFrame.new(targetPos, orePos)
    task.wait(0.3)

    -- ALWAYS 65% for ALL ores
    addLog("Mining: " .. oreData.name .. " (65% power)", Color3.fromRGB(150, 0, 255))

    local startTime = os.clock()
    local hits = 0
    local maxHits = 30

    while oreModel and oreModel:IsDescendantOf(workspace)
        and hittablePart and hittablePart.Parent
        and os.clock() - startTime < Module.mineTimeout
        and hits < maxHits do

        if (Module.HRP.Position - targetPos).Magnitude > 5 then
            Module.HRP.CFrame = CFrame.new(targetPos, orePos)
            task.wait(0.1)
        end

        simulateClickOnOre(hittablePart)
        sendCharge(hittablePart)
        task.wait(0.1)
        sendPerfectHit(hittablePart)

        hits = hits + 1
        task.wait(Module.mineInterval)

        if not hittablePart or not hittablePart.Parent then
            addLog("Mined! " .. oreData.name .. " (" .. hits .. " hits)", Color3.fromRGB(0, 255, 100))
            Module.isMining = false
            Module.currentTarget = nil
            return true
        end
    end

    Module.isMining = false
    Module.currentTarget = nil
    return hits > 0
end

--// Auto-Mine Loop
local function startAutoMine()
    if Module.autoMineLoop then return end
    Module.autoMineLoop = true
    addLog("Auto-mine started (65% power, radius: " .. Module.mineRadius .. ")", Color3.fromRGB(0, 255, 200))

    task.spawn(function()
        while Module.autoMineLoop and Module.enabled do
            if not Module.autoMineEnabled then
                task.wait(0.5)
                continue
            end

            if Module.isMining then
                task.wait(0.5)
                continue
            end

            local ores = findOresInRadius(Module.mineRadius)
            if #ores == 0 then
                task.wait(1)
                continue
            end

            local success = mineOre(ores[1])
            if success then task.wait(0.5) else task.wait(1) end
        end
        addLog("Auto-mine stopped", Color3.fromRGB(255, 100, 100))
    end)
end

local function stopAutoMine()
    Module.autoMineLoop = false
    Module.isMining = false
    Module.currentTarget = nil
end

--// Perfect Hit Handler (from DelayBar)
function Module.SetupDelayBarHandler()
    if not Module.Remotes or not Module.Remotes.DelayBar then return end

    trackConnection(Module.Remotes.DelayBar.OnClientEvent:Connect(function(data)
        if not Module.enabled or not Module.perfectEnabled then return end
        if not data then return end

        if data.ActionType == "Timed" then
            -- ALWAYS 65% for everything
            sendPerfectHit(nil)
            addLog("Perfect hit! 65% power", Color3.fromRGB(0, 255, 100))
        end
    end))
end

--// Character Respawn Handler
function Module.SetupCharacterHandler()
    if not Module.Player then return end

    trackConnection(Module.Player.CharacterAdded:Connect(function(newChar)
        Module.Character = newChar
        Module.Humanoid = newChar:WaitForChild("Humanoid")
        Module.HRP = newChar:WaitForChild("HumanoidRootPart")
        addLog("Character respawned", Color3.fromRGB(200, 200, 200))
    end))
end

--// GUI Integration - ONLY depends on hub Window
function Module.CreateGUI(hubWindow)
    local tab = hubWindow:AddTab({ Title = "Perfect Mine", Icon = "pickaxe" })

    tab:AddParagraph({
        Title = "Perfect Mine",
        Content = "100% hit rate | 65% power for ALL ores"
    })

    -- Enable Toggle
    local enableToggle = tab:AddToggle("PerfectMineEnabled", {
        Title = "Enable Module",
        Description = "Master switch",
        Default = false
    })

    enableToggle:OnChanged(function()
        Module.enabled = enableToggle.Value
        if not Module.enabled then stopAutoMine() end
        addLog(Module.enabled and "Module enabled" or "Module disabled", 
            Module.enabled and Color3.fromRGB(0, 255, 200) or Color3.fromRGB(255, 100, 100))
    end)

    -- Perfect Hit Toggle
    local perfectToggle = tab:AddToggle("PerfectHit", {
        Title = "100% Perfect Hit",
        Description = "Always perfect timing",
        Default = true
    })

    perfectToggle:OnChanged(function()
        Module.perfectEnabled = perfectToggle.Value
    end)

    -- 65% Power Toggle
    local powerToggle = tab:AddToggle("PowerLimit", {
        Title = "65% Power",
        Description = "Limit power to 65% for ALL ores",
        Default = true
    })

    powerToggle:OnChanged(function()
        Module.powerLimitEnabled = powerToggle.Value
        addLog("65% power: " .. (Module.powerLimitEnabled and "ON" or "OFF"),
            Module.powerLimitEnabled and Color3.fromRGB(150, 0, 255) or Color3.fromRGB(255, 100, 100))
    end)

    -- Auto-Mine Toggle
    local autoMineToggle = tab:AddToggle("AutoMine", {
        Title = "Auto-Mine",
        Description = "Automatically mine ores in radius",
        Default = false
    })

    autoMineToggle:OnChanged(function()
        Module.autoMineEnabled = autoMineToggle.Value
        if Module.autoMineEnabled and Module.enabled then
            startAutoMine()
        else
            stopAutoMine()
        end
    end)

    -- Radius Slider
    tab:AddSlider("MineRadius", {
        Title = "Mine Radius",
        Description = "Scan radius (studs)",
        Default = 10,
        Min = 5,
        Max = 50,
        Rounding = 0,
        Callback = function(v) Module.mineRadius = v end
    })

    -- Interval Slider
    tab:AddSlider("MineInterval", {
        Title = "Hit Interval",
        Description = "Seconds between hits",
        Default = 0.4,
        Min = 0.1,
        Max = 2,
        Rounding = 2,
        Callback = function(v) Module.mineInterval = v end
    })

    -- Status
    local statusLabel = tab:AddParagraph({
        Title = "Status",
        Content = "Idle"
    })

    -- Logs
    local logsLabel = tab:AddParagraph({
        Title = "Logs",
        Content = "No logs yet"
    })

    -- Update loop
    task.spawn(function()
        while true do
            task.wait(0.5)
            if not Module.enabled then
                statusLabel:SetDesc("Disabled")
                continue
            end

            local status = Module.isMining and ("Mining: " .. (Module.currentTarget and Module.currentTarget.name or "..."))
                or (Module.autoMineEnabled and "Auto-mine (" .. Module.mineRadius .. " studs)" 
                or ("Ready | 65%: " .. (Module.powerLimitEnabled and "ON" or "OFF")))
            statusLabel:SetDesc(status)

            local logText = ""
            for i = math.max(1, #Module.logs - 4), #Module.logs do
                local log = Module.logs[i]
                if log then
                    logText = logText .. "[" .. string.format("%.1f", log.time % 100) .. "] " .. log.text .. "
"
                end
            end
            logsLabel:SetDesc(logText ~= "" and logText or "No logs yet")
        end
    end)

    -- Manual Mine Button
    tab:AddButton({
        Title = "Mine Nearest",
        Description = "Mine closest ore in radius",
        Callback = function()
            if not Module.enabled then addLog("Enable first!", Color3.fromRGB(255, 100, 100)); return end
            local ores = findOresInRadius(Module.mineRadius)
            if #ores == 0 then addLog("No ores!", Color3.fromRGB(255, 100, 100)); return end
            task.spawn(function() mineOre(ores[1]) end)
        end
    })

    -- Mine All Button
    tab:AddButton({
        Title = "Mine All",
        Description = "Mine all ores in radius",
        Callback = function()
            if not Module.enabled then addLog("Enable first!", Color3.fromRGB(255, 100, 100)); return end
            task.spawn(function()
                while Module.enabled do
                    local ores = findOresInRadius(Module.mineRadius)
                    if #ores == 0 then addLog("Done!", Color3.fromRGB(0, 255, 100)); break end
                    if not mineOre(ores[1]) then task.wait(1) end
                    task.wait(0.5)
                end
            end)
        end
    })

    return tab
end

--// Cleanup
function Module.Destroy()
    Module.enabled = false
    stopAutoMine()
    clearConnections()
    Module.logs = {}
    addLog("Module destroyed", Color3.fromRGB(255, 100, 100))
end

--// Export
addLog("Perfect Mine Module loaded (65% for ALL ores)", Color3.fromRGB(0, 255, 200))
addLog("Zero dependencies - requires hub Setup()", Color3.fromRGB(200, 200, 200))

return Module
