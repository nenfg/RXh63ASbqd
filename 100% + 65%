--// Module State
local Module = {
    enabled = false,
    perfectEnabled = true,
    powerLimitEnabled = true,
    autoMineEnabled = false,
    mineRadius = 10,
    mineInterval = 0.4,
    mineTimeout = 15,
    blastshardLimit = 0.65,
    voltshardLimit = 0.65,
    normalAlpha = 1,
    normalResponseTime = 0.76456,
    connections = {},
    activeOres = {},
    isMining = false,
    currentTarget = nil,
    logs = {}
}

--// Utility Functions
local function trackConnection(conn)
    if conn then table.insert(Module.connections, conn) end
    return conn
end

local function clearConnections()
    for _, conn in ipairs(Module.connections) do
        pcall(function() conn:Disconnect() end)
    end
    Module.connections = {}
end

local function addLog(text, color)
    color = color or Color3.fromRGB(220, 220, 230)
    table.insert(Module.logs, {text = text, color = color, time = os.clock()})
    if #Module.logs > 50 then table.remove(Module.logs, 1) end
    if Module.onLog then Module.onLog(text, color) end
end

--// Get Equipped Pickaxe
local function getEquippedPickaxe()
    local char = player.Character
    if not char then return nil end
    for _, child in ipairs(char:GetChildren()) do
        if child:IsA("Tool") and (child.Name:find("Pickaxe") or child:GetAttribute("ToolType") == "Pickaxe") then
            return child
        end
    end
    return nil
end

--// Equip Pickaxe from Backpack
local function equipPickaxe()
    local char = player.Character
    if not char then return false end
    local backpack = player:FindFirstChild("Backpack")
    if not backpack then return false end
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return false end

    -- Check if already equipped
    if getEquippedPickaxe() then return true end

    for _, child in ipairs(backpack:GetChildren()) do
        if child:IsA("Tool") and (child.Name:find("Pickaxe") or child:GetAttribute("ToolType") == "Pickaxe") then
            humanoid:EquipTool(child)
            task.wait(0.3)
            return getEquippedPickaxe() ~= nil
        end
    end
    return false
end

--// Find Hittable Part in Ore Model
local function getHittablePart(oreModel)
    if not oreModel then return nil end

    -- Look for Hittable folder
    local hittable = oreModel:FindFirstChild("Hittable")
    if hittable then
        for _, child in ipairs(hittable:GetChildren()) do
            if child:IsA("BasePart") then
                return child
            end
        end
    end

    -- Fallback: Hitbox
    local hitbox = oreModel:FindFirstChild("Hitbox")
    if hitbox and hitbox:IsA("BasePart") then
        return hitbox
    end

    -- Fallback: any BasePart in model
    for _, child in ipairs(oreModel:GetDescendants()) do
        if child:IsA("BasePart") then
            return child
        end
    end

    return nil
end

--// Check if Ore is Blastshard/Voltshard
local function isPowerLimitedOre(oreName, parentName)
    oreName = (oreName or ""):lower()
    parentName = (parentName or ""):lower()
    return oreName:find("blastshard") or parentName:find("blastshard") or
           oreName:find("voltshard") or parentName:find("voltshard")
end

--// Send Perfect Hit
local function sendPerfectHit(targetOre, alpha, responseTime)
    alpha = alpha or Module.normalAlpha
    responseTime = responseTime or Module.normalResponseTime

    if not attackEvent then 
        addLog("Attack event not found!", Color3.fromRGB(255, 50, 50))
        return 
    end

    pcall(function()
        attackEvent:FireServer({
            Alpha = alpha,
            ResponseTime = responseTime,
            AnimSpeed = 1,
            DamageMultiplier = 1,
            Target = targetOre,
            HitPosition = targetOre and targetOre.CFrame or CFrame.new()
        })
    end)
end

--// Send Charge (for mining initiation)
local function sendCharge(targetOre, alpha)
    alpha = alpha or Module.normalAlpha

    if not chargeEvent then
        addLog("Charge event not found!", Color3.fromRGB(255, 50, 50))
        return
    end

    pcall(function()
        chargeEvent:FireServer({
            HitPosition = targetOre and targetOre.CFrame or CFrame.new(),
            Target = targetOre,
            Alpha = alpha
        })
    end)
end

--// Get Ore Position (for teleport)
local function getOrePosition(oreModel)
    local hittable = getHittablePart(oreModel)
    if hittable then return hittable.Position end

    -- Fallback to PrimaryPart or any part
    if oreModel.PrimaryPart then
        return oreModel.PrimaryPart.Position
    end

    for _, child in ipairs(oreModel:GetDescendants()) do
        if child:IsA("BasePart") then
            return child.Position
        end
    end

    return nil
end

--// Find Ores in Radius
local function findOresInRadius(radius)
    radius = radius or Module.mineRadius
    local char = player.Character
    if not char then return {} end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return {} end

    local found = {}
    local playerPos = hrp.Position

    -- Scan WorldSpawn/Ores
    local worldSpawn = workspace:FindFirstChild("WorldSpawn")
    if worldSpawn then
        local oresFolder = worldSpawn:FindFirstChild("Ores")
        if oresFolder then
            for _, ore in ipairs(oresFolder:GetChildren()) do
                if ore.Name ~= "_Decoration" then
                    local pos = getOrePosition(ore)
                    if pos then
                        local dist = (playerPos - pos).Magnitude
                        if dist <= radius then
                            table.insert(found, {
                                model = ore,
                                part = getHittablePart(ore),
                                position = pos,
                                distance = dist,
                                name = ore.Name
                            })
                        end
                    end
                end
            end
        end

        -- Trees
        local treesFolder = worldSpawn:FindFirstChild("Trees")
        if treesFolder then
            for _, tree in ipairs(treesFolder:GetChildren()) do
                if tree.Name ~= "_Decoration" then
                    local pos = getOrePosition(tree)
                    if pos then
                        local dist = (playerPos - pos).Magnitude
                        if dist <= radius then
                            table.insert(found, {
                                model = tree,
                                part = getHittablePart(tree),
                                position = pos,
                                distance = dist,
                                name = tree.Name,
                                isTree = true
                            })
                        end
                    end
                end
            end
        end
    end

    -- Sort by distance (closest first)
    table.sort(found, function(a, b) return a.distance < b.distance end)
    return found
end

--// Mine Single Ore
local function mineOre(oreData)
    if Module.isMining then return false end
    Module.isMining = true
    Module.currentTarget = oreData

    local char = player.Character
    if not char then 
        Module.isMining = false
        return false 
    end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then 
        Module.isMining = false
        return false 
    end

    local oreModel = oreData.model
    local hittablePart = oreData.part
    if not hittablePart or not hittablePart.Parent then
        Module.isMining = false
        return false
    end

    -- Equip pickaxe
    if not equipPickaxe() then
        addLog("No pickaxe found!", Color3.fromRGB(255, 50, 50))
        Module.isMining = false
        return false
    end
    task.wait(0.3)

    -- Calculate position (stand below ore for Diamond/Emerald, normal for others)
    local orePos = hittablePart.Position
    local oreName = oreData.name:lower()
    local targetPos = orePos

    if oreName:find("diamond") or oreName:find("emerald") or oreName:find("pink") then
        targetPos = orePos - Vector3.new(0, 8, 0)
        addLog("Mining from below: " .. oreData.name, Color3.fromRGB(255, 150, 0))
    else
        -- Stand at normal distance
        local direction = (hrp.Position - orePos)
        if direction.Magnitude < 0.1 then direction = Vector3.new(1, 0, 0) end
        direction = direction.Unit
        local standDistance = math.max(hittablePart.Size.X, hittablePart.Size.Z, 3) + 3
        targetPos = orePos + direction * standDistance
        targetPos = Vector3.new(targetPos.X, orePos.Y + 2, targetPos.Z)
    end

    -- Teleport to ore
    hrp.CFrame = CFrame.new(targetPos, orePos)
    task.wait(0.3)

    -- Determine alpha based on ore type
    local alpha = Module.normalAlpha
    local responseTime = Module.normalResponseTime

    if Module.powerLimitEnabled and isPowerLimitedOre(oreData.name, oreModel.Name) then
        alpha = Module.blastshardLimit
        responseTime = Module.voltshardLimit
        addLog("65% power for " .. oreData.name, Color3.fromRGB(150, 0, 255))
    end

    -- Start mining loop
    local startTime = os.clock()
    local hits = 0
    local maxHits = 30

    addLog("Mining: " .. oreData.name .. " (" .. math.floor(oreData.distance) .. "m)", Color3.fromRGB(0, 255, 200))

    while oreModel and oreModel:IsDescendantOf(workspace) 
          and hittablePart and hittablePart.Parent
          and os.clock() - startTime < Module.mineTimeout 
          and hits < maxHits do

        -- Maintain position
        if (hrp.Position - targetPos).Magnitude > 5 then
            hrp.CFrame = CFrame.new(targetPos, orePos)
            task.wait(0.1)
        end

        -- Send charge + attack
        sendCharge(hittablePart, alpha)
        task.wait(0.1)
        sendPerfectHit(hittablePart, alpha, responseTime)

        hits = hits + 1
        task.wait(Module.mineInterval)

        -- Check if ore destroyed
        if not hittablePart or not hittablePart.Parent then
            addLog("Mined! " .. oreData.name .. " (" .. hits .. " hits)", Color3.fromRGB(0, 255, 100))
            Module.isMining = false
            Module.currentTarget = nil
            return true
        end
    end

    if hits >= maxHits then
        addLog("Max hits reached for " .. oreData.name, Color3.fromRGB(255, 150, 0))
    else
        addLog("Timeout mining " .. oreData.name, Color3.fromRGB(255, 150, 0))
    end

    Module.isMining = false
    Module.currentTarget = nil
    return hits > 0
end

--// Auto-Mine Loop
local function startAutoMine()
    if Module.autoMineLoop then return end

    Module.autoMineLoop = true
    addLog("Auto-mine started (radius: " .. Module.mineRadius .. ")", Color3.fromRGB(0, 255, 200))

    task.spawn(function()
        while Module.autoMineLoop and Module.enabled do
            if not Module.autoMineEnabled then
                task.wait(0.5)
                continue
            end

            if Module.isMining then
                task.wait(0.5)
                continue
            end

            -- Find ores in radius
            local ores = findOresInRadius(Module.mineRadius)
            if #ores == 0 then
                addLog("No ores in " .. Module.mineRadius .. " studs", Color3.fromRGB(255, 150, 0))
                task.wait(1)
                continue
            end

            addLog("Found " .. #ores .. " ores nearby", Color3.fromRGB(0, 255, 150))

            -- Mine closest ore
            local success = mineOre(ores[1])
            if success then
                task.wait(0.5)
            else
                task.wait(1)
            end
        end

        addLog("Auto-mine stopped", Color3.fromRGB(255, 100, 100))
    end)
end

local function stopAutoMine()
    Module.autoMineLoop = false
    Module.isMining = false
    Module.currentTarget = nil
end

--// Perfect Hit Handler (from DelayBar)
if delayBarEvent and delayBarEvent:IsA("RemoteEvent") then
    trackConnection(delayBarEvent.OnClientEvent:Connect(function(data, extra)
        if not Module.enabled or not Module.perfectEnabled then return end
        if not data then return end

        if data.ActionType == "Timed" then
            -- Check current target for power limit
            local alpha = Module.normalAlpha
            local responseTime = Module.normalResponseTime

            if Module.currentTarget and Module.powerLimitEnabled then
                if isPowerLimitedOre(Module.currentTarget.name, Module.currentTarget.model.Name) then
                    alpha = Module.blastshardLimit
                    responseTime = Module.voltshardLimit
                end
            end

            sendPerfectHit(nil, alpha, responseTime)
            addLog("Perfect hit! Alpha: " .. alpha, Color3.fromRGB(0, 255, 100))
        end
    end))
end

