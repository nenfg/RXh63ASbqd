--// GUI Integration (for LO Hub)
function Module.CreateGUI(parent)
    local tab = parent:AddTab({ Title = "Perfect Mine", Icon = "pickaxe" })

    -- Enable Toggle
    local enableToggle = tab:AddToggle("PerfectMineEnabled", {
        Title = "Enable Module",
        Description = "Master switch for perfect mining",
        Default = false
    })

    enableToggle:OnChanged(function()
        Module.enabled = enableToggle.Value
        if Module.enabled then
            addLog("Module enabled", Color3.fromRGB(0, 255, 200))
        else
            stopAutoMine()
            addLog("Module disabled", Color3.fromRGB(255, 100, 100))
        end
    end)

    -- Perfect Hit Toggle
    local perfectToggle = tab:AddToggle("PerfectHit", {
        Title = "100% Perfect Hit",
        Description = "Always hit perfect timing",
        Default = true
    })

    perfectToggle:OnChanged(function()
        Module.perfectEnabled = perfectToggle.Value
        addLog("Perfect hit: " .. (Module.perfectEnabled and "ON" or "OFF"), 
            Module.perfectEnabled and Color3.fromRGB(0, 255, 200) or Color3.fromRGB(255, 100, 100))
    end)

    -- 65% Power Limit Toggle
    local powerLimitToggle = tab:AddToggle("PowerLimit", {
        Title = "65% Power Limit",
        Description = "Limit power for Blastshard/Voltshard",
        Default = true
    })

    powerLimitToggle:OnChanged(function()
        Module.powerLimitEnabled = powerLimitToggle.Value
        addLog("Power limit: " .. (Module.powerLimitEnabled and "ON" or "OFF"),
            Module.powerLimitEnabled and Color3.fromRGB(150, 0, 255) or Color3.fromRGB(255, 100, 100))
    end)

    -- Auto-Mine Toggle
    local autoMineToggle = tab:AddToggle("AutoMine", {
        Title = "Auto-Mine Radius",
        Description = "Automatically mine ores in radius",
        Default = false
    })

    autoMineToggle:OnChanged(function()
        Module.autoMineEnabled = autoMineToggle.Value
        if Module.autoMineEnabled and Module.enabled then
            startAutoMine()
        else
            stopAutoMine()
        end
    end)

    -- Radius Slider
    local radiusSlider = tab:AddSlider("MineRadius", {
        Title = "Mine Radius",
        Description = "Radius to scan for ores (studs)",
        Default = 10,
        Min = 5,
        Max = 50,
        Rounding = 0
    })

    radiusSlider:OnChanged(function(value)
        Module.mineRadius = value
    end)

    -- Interval Slider
    local intervalSlider = tab:AddSlider("MineInterval", {
        Title = "Hit Interval",
        Description = "Seconds between hits",
        Default = 0.4,
        Min = 0.1,
        Max = 2,
        Rounding = 2
    })

    intervalSlider:OnChanged(function(value)
        Module.mineInterval = value
    end)

    -- Status Display
    local statusLabel = tab:AddParagraph({
        Title = "Status",
        Content = "Idle"
    })

    -- Logs Display
    local logsLabel = tab:AddParagraph({
        Title = "Logs",
        Content = "No logs yet"
    })

    -- Update status loop
    task.spawn(function()
        while true do
            task.wait(0.5)
            if not Module.enabled then
                statusLabel:SetContent("Module disabled")
                continue
            end

            local status = ""
            if Module.isMining then
                status = "Mining: " .. (Module.currentTarget and Module.currentTarget.name or "Unknown")
            elseif Module.autoMineEnabled then
                status = "Auto-mine active (" .. Module.mineRadius .. " studs)"
            else
                status = "Ready - " .. (Module.perfectEnabled and "100% hit ON" or "Manual") 
                    .. " - " .. (Module.powerLimitEnabled and "65% limit ON" or "No limit")
            end
            statusLabel:SetContent(status)

            -- Update logs
            local logText = ""
            for i = math.max(1, #Module.logs - 4), #Module.logs do
                local log = Module.logs[i]
                if log then
                    logText = logText .. "[" .. string.format("%.1f", log.time % 100) .. "] " .. log.text .. "\n"
                end
            end
            if logText == "" then logText = "No logs yet" end
            logsLabel:SetContent(logText)
        end
    end)

    -- Manual Mine Button
    tab:AddButton({
        Title = "Mine Nearest Ore",
        Description = "Manually mine closest ore in radius",
        Callback = function()
            if not Module.enabled then
                addLog("Enable module first!", Color3.fromRGB(255, 100, 100))
                return
            end

            local ores = findOresInRadius(Module.mineRadius)
            if #ores == 0 then
                addLog("No ores found!", Color3.fromRGB(255, 100, 100))
                return
            end

            task.spawn(function()
                mineOre(ores[1])
            end)
        end
    })

    -- Mine All Button
    tab:AddButton({
        Title = "Mine All in Radius",
        Description = "Mine all ores in radius one by one",
        Callback = function()
            if not Module.enabled then
                addLog("Enable module first!", Color3.fromRGB(255, 100, 100))
                return
            end

            task.spawn(function()
                while Module.enabled do
                    local ores = findOresInRadius(Module.mineRadius)
                    if #ores == 0 then
                        addLog("All ores mined!", Color3.fromRGB(0, 255, 100))
                        break
                    end

                    local success = mineOre(ores[1])
                    if not success then
                        task.wait(1)
                    end
                    task.wait(0.5)
                end
            end)
        end
    })

    return tab
end

--// Cleanup
function Module.Destroy()
    Module.enabled = false
    stopAutoMine()
    clearConnections()
    Module.logs = {}
    addLog("Module destroyed", Color3.fromRGB(255, 100, 100))
end

